<mvc:View
	controllerName="ui5.sales.controller.App"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	displayBlock="true">
	<App>
		<Page title="Sales Orders">
			<Text text="{/appTitle}" class="sapUiSmallMargin" />
			<Input placeholder="Type a customer name" change=".onInputChange" class="sapUiSmallMargin" />
			<Button id="helloButton" text="Say hello" press=".onShowHello" />
		</Page>
	</App>
</mvc:View>
