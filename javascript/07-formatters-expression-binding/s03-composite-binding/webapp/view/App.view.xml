<mvc:View
	controllerName="ui5.sales.controller.App"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:l="sap.ui.layout"
	displayBlock="true">
	<App>
		<Page>
			<customHeader>
				<Bar>
					<contentMiddle>
						<Title text="Sales Orders" level="H1" />
					</contentMiddle>
				</Bar>
			</customHeader>
			<content>
				<l:Grid defaultSpan="XL3 L3 M6 S12" hSpacing="1" vSpacing="1" class="sapUiSmallMargin">
						<VBox class="sapUiSmallMargin">
							<Title text="{/kpi/open}" level="H2" />
							<Text text="Open orders" />
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Title text="{/kpi/inProcess}" level="H2" />
							<Text text="In process" />
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Title text="{/kpi/completed}" level="H2" />
							<Text text="Completed" />
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Title text="{/kpi/revenue}" level="H2" />
							<Text text="Revenue" />
						</VBox>
				</l:Grid>
				<SearchField search=".onSearch" placeholder="Search by customer" class="sapUiResponsiveMargin" width="20rem" />
				<List id="ordersList" headerText="Sales orders" items="{ path: '/salesOrders', sorter: { path: 'orderDate', descending: true } }" class="sapUiResponsiveMargin">
					<ObjectListItem title="{customer}" number="{amount}" numberUnit="{currency}" type="Active" press=".onOrderPress" highlight="{= ${priority} === 'High' ? 'Error' : 'None' }">
						<firstStatus>
							<ObjectStatus text="{status}" state="{ path: 'status', formatter: '.formatter.statusState' }" />
						</firstStatus>
						<attributes>
							<ObjectAttribute text="{orderId}" />
						</attributes>
					</ObjectListItem>
				</List>
				<Panel id="detailPanel" headerText="Order details" class="sapUiResponsiveMargin">
					<Text text="Customer: {customer}" />
					<Text text="Status: {status}" />
					<Text text="Amount: {amount} {currency}" />
					<Text text="{ parts: ['customer', 'orderId'], formatter: '.formatter.customerLine' }" />
				</Panel>
			</content>
			<footer>
				<OverflowToolbar>
					<ToolbarSpacer />
					<Button text="Create" type="Emphasized" press=".onCreate" />
					<Button id="refreshButton" text="Refresh" icon="sap-icon://refresh" visible="{= !${device>/isPhone} }" />
				</OverflowToolbar>
			</footer>
		</Page>
	</App>
</mvc:View>
