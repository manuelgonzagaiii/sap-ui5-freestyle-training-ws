<mvc:View
	controllerName="ui5.sales.controller.Detail"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	displayBlock="true">
	<Page title="{i18n>detailTitle}" showNavButton="true" navButtonPress=".onBack">
		<content>
			<ObjectHeader title="{customer}" number="{ parts: ['amount', 'currency'], type: 'sap.ui.model.type.Currency', formatOptions: { showMeasure: false } }" numberUnit="{currency}">
				<statuses>
					<ObjectStatus text="{status}" state="{ path: 'status', formatter: '.formatter.statusState' }" />
				</statuses>
				<attributes>
					<ObjectAttribute title="Order" text="{orderId}" />
					<ObjectAttribute title="Date" text="{ path: 'orderDate', type: 'sap.ui.model.type.Date', formatOptions: { source: { pattern: 'yyyy-MM-dd' }, style: 'long' } }" />
					<ObjectAttribute title="Items" text="{ path: 'itemCount', type: 'ui5.sales.model.ItemCountType' }" />
				</attributes>
			</ObjectHeader>
		</content>
	</Page>
</mvc:View>
